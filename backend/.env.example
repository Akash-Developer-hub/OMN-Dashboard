# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=OMN

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/omn
MONGODB_URI_TEST=mongodb://localhost:27017/omn_test

# ============================================
# JWT SECRETS
# ============================================
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_ACCESS_EXPIRY=100d
JWT_REFRESH_EXPIRY=7d

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ============================================
# ACCOUNT SECURITY
# ============================================
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ============================================
# EVENT LOOP MONITORING
# ============================================
EVENT_LOOP_DELAY_THRESHOLD_MS=100
EVENT_LOOP_CHECK_INTERVAL_MS=5000

# ============================================
# SECURITY
# ============================================
COOKIE_SECRET=your-cookie-secret-change-this
ENCRYPTION_KEY=your-32-char-encryption-key-here-12345

# ============================================
# SWAGGER
# ============================================
SWAGGER_ENABLED=true
SWAGGER_ENFORCE_DOCS=true

# ============================================
# ADMIN
# ============================================
ADMIN_NETWORK_WHITELIST=127.0.0.1,::1
ADMIN_DASHBOARD_EMAIL=admin@omn.com
# The superadmin email has full access: create, update (role/isActive), delete users
SUPER_ADMIN_EMAIL=admin@omn.com
# ============================================
# GTFS REALTIME
# ============================================
GTFS_FEED_URL=https://gtfsr.itc.gov.ae
GTFS_AUTH=Basic QVBJTG9naW5BRE1hcDokNE81eX1tIjh5TVt9MHFcbHQ=
GTFS_PROTO_URL=https://raw.githubusercontent.com/google/transit/master/gtfs-realtime/proto/gtfs-realtime.proto
# ============================================
# AZURE BLOB STORAGE
AZURE_STORAGE_SAS_URL=xxxx
AZURE_STORAGE_CONTAINER_NAME=xxxx

# ============================================
# RSP INCIDENT SOAP SERVICE
# ============================================
RSP_SOAP_URL=http://dtdev.fleetman.ae/DMATIncidentsService/WebServices/DMATIncidentsService.asmx
RSP_SOAP_USERNAME=DMATAdmin
RSP_SOAP_PASSWORD=DMAT@123
RSP_SOAP_INTERFACE_ID=11

# ============================================
# IMS REST SERVICE
# ============================================
IMS_REST_URL=https://geotrans.itc.gov.ae/soa-infra/resources/ITC_SERVICES/GBL_ITC_CRM_ADMAPS_IMS_DOTIncidentsService/ADMAPS_IMS_DOTIncidents/InsertIMSIncidentData
IMS_BASIC_TOKEN=
IMS_INTERFACE_ID=ITC_CRM_ADMAPS_IMS_201
IMS_REST_TIMEOUT=500000

# ============================================
# CONTRIBUTION GENERATION
# ============================================
UPDATE_ISLIVE_URL=http://localhost:3000/api/v1/admin-dashboard/contributors/update-contribution-islive
N8N_WEBHOOK_URL=https://sandbox.vmmaps.com/n8n/webhook/start-contributions