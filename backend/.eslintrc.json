{
    "env": {
        "node": true,
        "es2024": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:security/recommended-legacy"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": [
        "security"
    ],
    "rules": {
        "no-eval": "error",
        "no-implied-eval": "error",
        "no-new-func": "error",
        "security/detect-object-injection": "warn",
        "security/detect-non-literal-regexp": "warn",
        "security/detect-non-literal-fs-filename": "warn",
        "security/detect-possible-timing-attacks": "warn",
        "no-console": "warn",
        "no-unused-vars": [
            "error",
            {
                "argsIgnorePattern": "^_"
            }
        ],
        "prefer-const": "error",
        "no-var": "error"
    }
}